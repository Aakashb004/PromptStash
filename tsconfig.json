{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,

    "lib": [
      "DOM",
      "ES2022"
    ],

    "types": [
      "chrome"
    ],

    "skipLibCheck": true,

    "allowSyntheticDefaultImports": true,

    "isolatedModules": true,

    "noEmit": true
  },

  "include": [
    "src",
    "vite.config.ts"
  ]
}